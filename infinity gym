<style>
  :root{
    --bg: #0a0a0c;
    --bg-2: #111114;
    --surface: #17171b;
    --surface-2: #1e1e24;
    --line: #2a2a30;
    --text: #f3f3ef;
    --muted: #97979f;
    --neon: #d7ff3f;
    --neon-dim: #a8cc2c;
    --cyan: #23e5d3;
    --radius: 2px;
  }

  *{ margin:0; padding:0; box-sizing:border-box; }

  html{ scroll-behavior:smooth; }

  body{
    background:
      radial-gradient(ellipse 80% 50% at 50% -10%, rgba(215,255,63,0.07), transparent),
      var(--bg);
    color: var(--text);
    font-family: 'Inter', sans-serif;
    -webkit-font-smoothing: antialiased;
    overflow-x: hidden;
  }

  .display{ font-family:'Bebas Neue', sans-serif; letter-spacing:0.02em; }
  .mono{ font-family:'JetBrains Mono', monospace; }

  a{ color:inherit; text-decoration:none; }
  img{ max-width:100%; display:block; }

  ::selection{ background:var(--neon); color:#0a0a0c; }

  .wrap{ max-width:1180px; margin:0 auto; padding:0 24px; }

  .eyebrow{
    font-family:'JetBrains Mono', monospace;
    font-size:12px;
    letter-spacing:0.18em;
    text-transform:uppercase;
    color:var(--neon);
    display:flex;
    align-items:center;
    gap:10px;
    margin-bottom:18px;
  }
  .eyebrow::before{
    content:'';
    width:24px; height:1px;
    background:var(--neon);
  }

  /* NAV */
  header{
    position:fixed; top:0; left:0; right:0; z-index:100;
    background:rgba(10,10,12,0.75);
    backdrop-filter: blur(10px);
    border-bottom:1px solid var(--line);
  }
  .nav{
    display:flex; align-items:center; justify-content:space-between;
    padding:16px 24px;
    max-width:1180px; margin:0 auto;
  }
  .logo{
    font-family:'Bebas Neue', sans-serif;
    font-size:24px;
    letter-spacing:0.06em;
  }
  .logo span{ color:var(--neon); }
  .nav-links{ display:flex; gap:32px; font-size:13px; letter-spacing:0.04em; }
  .nav-links a{ color:var(--muted); transition:color .2s; }
  .nav-links a:hover{ color:var(--text); }
  .nav-cta{
    background:var(--neon); color:#0a0a0c; font-weight:700;
    padding:10px 18px; font-size:13px; border-radius:var(--radius);
    letter-spacing:0.02em;
  }
  .nav-mobile-toggle{ display:none; }

  @media (max-width:820px){
    .nav-links{ display:none; }
  }

  /* HERO */
  .hero{
    padding:170px 0 90px;
    position:relative;
    overflow:hidden;
  }
  .hero-bg{
    position:absolute; inset:0;
    background-image:
      linear-gradient(180deg, rgba(10,10,12,0.55) 0%, rgba(10,10,12,0.88) 55%, var(--bg) 100%),
      url('data:image/webp;base64,');
    background-size:cover;
    background-position:center 30%;
    z-index:0;
  }
  .hero-grid{ position:relative; z-index:1; }
  .hero-grid{
    display:grid;
    grid-template-columns: 1.15fr 0.85fr;
    gap:50px;
    align-items:end;
  }
  .hero h1{
    font-size:clamp(52px, 8vw, 108px);
    line-height:0.92;
    text-transform:uppercase;
  }
  .hero h1 .accent{ color:var(--neon); }
  .hero-sub{
    font-size:17px; color:var(--muted); line-height:1.65;
    max-width:520px; margin-top:22px;
  }
  .hero-cta{ display:flex; gap:14px; margin-top:34px; flex-wrap:wrap; }
  .btn{
    padding:15px 26px; font-size:14px; font-weight:700;
    border-radius:var(--radius); letter-spacing:0.02em;
    display:inline-flex; align-items:center; gap:10px;
    transition:transform .15s ease, box-shadow .15s ease;
  }
  .btn:hover{ transform:translateY(-2px); }
  .btn-primary{
    background:var(--neon); color:#0a0a0c;
    box-shadow:0 0 0 rgba(215,255,63,0);
  }
  .btn-primary:hover{ box-shadow:0 8px 30px -6px rgba(215,255,63,0.5); }
  .btn-outline{
    border:1px solid var(--line); color:var(--text);
    background:rgba(255,255,255,0.02);
  }
  .btn-outline:hover{ border-color:var(--neon); }

  .hero-card{
    background:var(--surface);
    border:1px solid var(--line);
    padding:26px;
    position:relative;
  }
  .hero-card::before{
    content:'';
    position:absolute; top:-1px; left:-1px; right:-1px; height:3px;
    background:linear-gradient(90deg, var(--neon), transparent);
  }
  .rating-row{ display:flex; align-items:baseline; gap:10px; }
  .rating-num{ font-family:'Bebas Neue'; font-size:56px; color:var(--neon); line-height:1; }
  .stars{ color:var(--neon); font-size:18px; letter-spacing:2px; }
  .rating-sub{ color:var(--muted); font-size:13px; margin-top:6px; }
  .hero-stats{
    display:grid; grid-template-columns:1fr 1fr; gap:18px;
    margin-top:24px; padding-top:22px; border-top:1px solid var(--line);
  }
  .hero-stats div .n{ font-family:'JetBrains Mono'; font-size:20px; color:var(--text); font-weight:600; }
  .hero-stats div .l{ font-size:11px; color:var(--muted); text-transform:uppercase; letter-spacing:0.08em; margin-top:4px; }

  @media (max-width:900px){
    .hero-grid{ grid-template-columns:1fr; }
  }

  /* MARQUEE - signature element */
  .marquee-band{
    border-top:1px solid var(--neon);
    border-bottom:1px solid var(--neon);
    background:#0e0e11;
    overflow:hidden;
    padding:16px 0;
    transform:skewY(-1.2deg);
    margin: 10px 0 60px;
  }
  .marquee-track{
    display:flex;
    width:max-content;
    animation:scroll 28s linear infinite;
  }
  .marquee-track span{
    font-family:'Bebas Neue';
    font-size:26px;
    letter-spacing:0.04em;
    color:var(--text);
    padding:0 22px;
    white-space:nowrap;
    display:flex;
    align-items:center;
    gap:22px;
  }
  .marquee-track span em{
    font-style:normal;
    color:var(--neon);
    text-shadow:0 0 14px rgba(215,255,63,0.6);
  }
  .marquee-track span::after{
    content:'●';
    color:var(--muted);
    font-size:10px;
    margin-left:22px;
  }
  @keyframes scroll{
    from{ transform:translateX(0); }
    to{ transform:translateX(-50%); }
  }
  @media (prefers-reduced-motion: reduce){
    .marquee-track{ animation:none; }
  }

  /* SECTION GENERIC */
  section{ padding:70px 0; }
  .section-head{ max-width:640px; margin-bottom:50px; }
  .section-head h2{
    font-family:'Bebas Neue';
    font-size:clamp(34px, 5vw, 54px);
    line-height:1.02;
    text-transform:uppercase;
  }

  /* PROGRAMS */
  .prog-grid{
    display:grid;
    grid-template-columns:repeat(4, 1fr);
    gap:1px;
    background:var(--line);
    border:1px solid var(--line);
  }
  .prog-card{
    background:var(--bg-2);
    padding:32px 26px;
    transition:background .2s;
  }
  .prog-card:hover{ background:var(--surface); }
  .prog-card .tag{
    font-family:'JetBrains Mono'; font-size:11px; color:var(--neon);
    letter-spacing:0.1em; text-transform:uppercase;
  }
  .prog-card h3{
    font-family:'Bebas Neue'; font-size:26px; margin-top:14px; line-height:1.05;
  }
  .prog-card p{ color:var(--muted); font-size:14px; line-height:1.6; margin-top:12px; }

  @media (max-width:900px){ .prog-grid{ grid-template-columns:1fr 1fr; } }
  @media (max-width:600px){ .prog-grid{ grid-template-columns:1fr; } }

  /* FACILITIES */
  .fac-wrap{
    display:grid;
    grid-template-columns: 0.9fr 1.1fr;
    gap:50px;
    align-items:start;
  }
  .fac-list{ display:flex; flex-direction:column; }
  .fac-item{
    display:flex; gap:18px; padding:20px 0;
    border-bottom:1px solid var(--line);
  }
  .fac-item:first-child{ padding-top:0; }
  .fac-num{ font-family:'JetBrains Mono'; color:var(--neon); font-size:13px; padding-top:3px; }
  .fac-item h4{ font-size:16px; font-weight:700; }
  .fac-item p{ color:var(--muted); font-size:14px; margin-top:6px; line-height:1.6; }

  .fac-visual{
    background:var(--surface);
    border:1px solid var(--line);
    padding:20px;
    height:100%;
  }
  .gallery-mosaic{
    display:grid;
    grid-template-columns:1fr 1fr;
    grid-template-rows:auto auto;
    gap:6px;
  }
  .gallery-mosaic img{
    width:100%; height:100%; object-fit:cover;
    filter:saturate(1.05) contrast(1.03);
  }
  .gallery-mosaic .g-tall{ grid-row:1 / 3; height:100%; min-height:220px; }
  .gallery-mosaic .g-short{ height:150px; }
  .amenity-grid{
    display:grid; grid-template-columns:1fr 1fr; gap:12px;
    margin-top:20px;
  }
  .amenity-chip{
    border:1px solid var(--line); padding:12px 14px;
    font-size:12px; color:var(--muted);
    display:flex; align-items:center; gap:8px;
  }
  .amenity-chip .dot{ width:6px; height:6px; background:var(--neon); border-radius:50%; flex-shrink:0; }

  @media (max-width:900px){ .fac-wrap{ grid-template-columns:1fr; } }

  /* GALLERY STRIP */
  .gallery-strip{
    display:grid;
    grid-template-columns: 1.4fr 1fr 1fr 1fr;
    gap:6px;
    height:340px;
  }
  .gallery-strip img{
    width:100%; height:100%; object-fit:cover;
    filter:saturate(1.05) contrast(1.03);
    transition:transform .4s ease, filter .4s ease;
  }
  .gallery-strip img:hover{ transform:scale(1.03); filter:saturate(1.2) contrast(1.05); }
  @media (max-width:900px){
    .gallery-strip{ grid-template-columns:1fr 1fr; grid-auto-rows:170px; height:auto; }
  }
  @media (max-width:520px){
    .gallery-strip{ grid-template-columns:1fr; }
  }

  /* MEMBERSHIP */
  .member-card{
    background:linear-gradient(135deg, var(--surface), var(--bg-2));
    border:1px solid var(--line);
    padding:50px;
    display:grid;
    grid-template-columns: 1fr auto;
    gap:40px;
    align-items:center;
    position:relative;
    overflow:hidden;
  }
  .member-card::after{
    content:'';
    position:absolute; right:-60px; top:-60px; width:220px; height:220px;
    background:radial-gradient(circle, rgba(215,255,63,0.12), transparent 70%);
  }
  .member-left .eyebrow{ margin-bottom:14px; }
  .member-left h3{ font-family:'Bebas Neue'; font-size:38px; }
  .member-feats{
    list-style:none; margin-top:20px; display:flex; flex-direction:column; gap:10px;
  }
  .member-feats li{ font-size:14px; color:var(--muted); display:flex; gap:10px; }
  .member-feats li::before{ content:'—'; color:var(--neon); }
  .member-note{ font-size:12px; color:var(--muted); margin-top:20px; max-width:420px; }

  .price-box{ text-align:right; }
  .price-box .amt{ font-family:'JetBrains Mono'; font-size:52px; font-weight:700; color:var(--neon); }
  .price-box .per{ color:var(--muted); font-size:13px; }
  .price-box .btn{ margin-top:18px; }

  @media (max-width:800px){
    .member-card{ grid-template-columns:1fr; padding:34px; }
    .price-box{ text-align:left; }
  }

  /* LOCATION */
  .loc-wrap{
    display:grid; grid-template-columns:1fr 1fr; gap:1px;
    background:var(--line); border:1px solid var(--line);
  }
  .loc-block{ background:var(--bg-2); padding:38px; }
  .loc-block h4{
    font-family:'JetBrains Mono'; font-size:12px; letter-spacing:0.1em;
    color:var(--neon); text-transform:uppercase; margin-bottom:16px;
  }
  .loc-address{ font-size:16px; line-height:1.7; color:var(--text); }
  .hours-row{
    display:flex; justify-content:space-between;
    padding:12px 0; border-bottom:1px solid var(--line);
    font-size:14px;
  }
  .hours-row:last-child{ border-bottom:none; }
  .hours-row .d{ color:var(--muted); }
  .hours-row .t{ font-family:'JetBrains Mono'; }

  /* CONTACT / FOOTER */
  .contact-cta{
    text-align:center; padding:100px 0 60px;
  }
  .contact-cta h2{
    font-family:'Bebas Neue'; font-size:clamp(40px,7vw,74px);
    text-transform:uppercase; line-height:1;
  }
  .contact-cta .accent{ color:var(--neon); }
  .contact-cta p{ color:var(--muted); margin-top:16px; max-width:480px; margin-left:auto; margin-right:auto; }
  .contact-buttons{
    display:flex; justify-content:center; gap:16px; margin-top:36px; flex-wrap:wrap;
  }

  footer{
    border-top:1px solid var(--line);
    padding:36px 0;
  }
  .footer-grid{
    display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:20px;
    font-size:13px; color:var(--muted);
  }
  .footer-links{ display:flex; gap:24px; }
  .footer-links a:hover{ color:var(--neon); }

  .reveal{ opacity:0; transform:translateY(24px); transition:opacity .6s ease, transform .6s ease; }
  .reveal.in{ opacity:1; transform:translateY(0); }
</style>
</head>
